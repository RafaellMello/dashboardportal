# ──────────────────────────────────────────────────────────────
# Portal do Contribuinte — Analytics Dashboard
# Copie este arquivo para .env e preencha os valores
# ──────────────────────────────────────────────────────────────

# ID da propriedade GA4 (somente os números)
# Exemplo: se sua propriedade é "properties/123456789", coloque 123456789
GA4_PROPERTY_ID=506024362

# Caminho para o arquivo JSON da Service Account
# Gerado no Google Cloud Console
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# Porta do servidor (padrão: 3000)
PORT=3000
